# Goc.B2 - Environment Configuration (example)
# Copy this to .env and fill in your values

# Upstash Redis (for SRS queue, session cache, streaks)
# Get these from your Upstash console -> REST API section
UPSTASH_REDIS_REST_URL=https://<region>-<name>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-upstash-token>
